{
  "description": "Tells Claude to use dv in Diversion repos, checkpoints chat before mutating tools, and stamps dv commit with the checkpoint id.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "dv claude-hook session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dv claude-hook pre-tool-use",
            "timeout": 20
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dv claude-hook post-tool-use",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "dv claude-hook session-end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
